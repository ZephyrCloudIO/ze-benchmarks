{
  "name": "ze-benchmarks",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm --filter ze-evaluator run build && pnpm --filter @ze/worker-client run build && pnpm --filter @ze/harness run build && pnpm --filter @ze/specialist-mint run build",
    "build:evals": "pnpm --filter ze-evaluator run build",
    "build:adapters": "pnpm --filter @ze/agent-adapters run build",
    "build:worker-client": "pnpm --filter @ze/worker-client run build",
    "build:mint": "pnpm --filter @ze/specialist-mint run build",
    "bench": "tsx packages/harness/src/cli.ts",
    "mint:snapshot": "pnpm --filter @ze/specialist-mint run mint:snapshot",
    "mint:enrich": "tsx packages/specialist-mint/src/cli.ts enrich:template",
    "dash:build": "pnpm --filter benchmark-report run build",
    "dash:dev": "pnpm --filter benchmark-report run dev",
    "worker:dev": "pnpm --filter ze-benchmarks-worker run dev",
    "worker:migrate": "pnpm --filter ze-benchmarks-worker run db:migrate:local",
    "worker:sync": "pnpm --filter ze-benchmarks-worker run db:sync-from-prod",
    "worker:deploy-dev": "pnpm --filter ze-benchmarks-worker run deploy:dev",
    "worker:deploy-staging": "pnpm --filter ze-benchmarks-worker run deploy:staging",
    "worker:deploy-production": "pnpm --filter ze-benchmarks-worker run deploy:production",
    "start:report": "pnpm --filter benchmark-report run dev",
    "definer:dev": "pnpm --filter definer run dev",
    "definer:build": "pnpm --filter definer run build"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/cli-progress": "3.11.6",
    "@types/figlet": "1.7.0",
    "tsx": "4.20.6"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@types/debug": "^4.1.12",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "debug": "^4.4.3",
    "dotenv": "^16.4.5",
    "figlet": "^1.9.3",
    "json5": "^2.2.3",
    "yaml": "^2.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "esbuild"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "jsondiffpatch": ">=0.7.2",
      "js-yaml": ">=4.1.1",
      "@modelcontextprotocol/sdk@<1.24.0": ">=1.24.0",
      "qs": ">=6.14.2",
      "@modelcontextprotocol/sdk@<1.25.2": ">=1.25.2",
      "react-router@<7.12.0": ">=7.12.0",
      "tar@<=7.5.3": ">=7.5.4",
      "wrangler@>=4.0.0 <4.59.1": ">=4.59.1",
      "seroval@<1.4.1": ">=1.4.1",
      "react-server-dom-webpack@>=19.0.0 <19.1.5": ">=19.1.5",
      "react-server-dom-turbopack@>=19.0.0 <19.1.5": ">=19.1.5",
      "react-server-dom-parcel@>=19.0.0 <19.1.5": ">=19.1.5",
      "body-parser@>=2.2.0 <2.2.1": ">=2.2.1",
      "next@<15.5.10": ">=15.5.10",
      "vite@>=6.0.0 <=6.4.0": ">=6.4.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "hono@<4.12.7": ">=4.12.7",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "express-rate-limit@>=8.2.0 <8.2.2": ">=8.2.2",
      "lodash@<=4.17.22": ">=4.17.23",
      "bn.js@<4.12.3": ">=4.12.3",
      "bn.js@>=5.0.0 <5.2.3": ">=5.2.3",
      "diff@>=6.0.0 <8.0.3": ">=8.0.3",
      "webpack@>=5.49.0 <5.104.1": ">=5.104.1",
      "axios@<=1.13.4": ">=1.13.5",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "jsondiffpatch@<0.7.2": ">=0.7.2"
    }
  }
}
